{
  "permissions": {
    "allow": [
      "Bash(npm --version)",
      "Bash(pnpm --version)",
      "Bash(git --version)",
      "Bash(docker --version)",
      "Bash(pnpm install *)",
      "Bash(pnpm rebuild *)",
      "Bash(pnpm --filter @agencyos/shared build)",
      "Bash(pnpm --filter @agencyos/backend build)",
      "Bash(pnpm --filter @agencyos/frontend build)",
      "Bash(DATABASE_URL=\"postgresql://x:x@localhost:5432/x\" pnpm --filter @agencyos/backend exec prisma validate)",
