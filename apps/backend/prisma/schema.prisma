// Prisma schema — single source of truth for the database.
// Change the schema via migrations only (never by hand).
// Multi-tenancy: nearly every table carries a tenantId; queries must be tenant-scoped.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
  READ_ONLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum OnboardingTaskStatus {
  PENDING
  DONE
  SKIPPED
}

/// A workspace = a tenant (a company or agency). The Owner is the subscriber.
model Tenant {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  logoUrl              String?
  timezone             String    @default("Asia/Dhaka")
  currency             String    @default("BDT")
  businessType         String?
  onboardingCompletedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users           User[]
  subscription    Subscription?
  onboardingTasks OnboardingTask[]

  @@map("tenants")
}

/// A step in the agency's getting-started checklist (seeded on registration).
model OnboardingTask {
  id          String               @id @default(cuid())
  tenantId    String
  key         String
  title       String
  status      OnboardingTaskStatus @default(PENDING)
  order       Int                  @default(0)
  completedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("onboarding_tasks")
}

/// Tenant-level subscription. Gates platform access for every user in the tenant.
model Subscription {
  id               String             @id @default(cuid())
  tenantId         String             @unique
  status           SubscriptionStatus @default(TRIALING)
  plan             String             @default("trial")
  maxSubUsers      Int                @default(10)
  currentPeriodEnd DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  name         String
  phone        String?
  passwordHash String
  role         UserRole  @default(AGENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([tenantId])
  @@map("users")
}

/// Hashed refresh tokens for rotation + revocation (one row per active session).
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
