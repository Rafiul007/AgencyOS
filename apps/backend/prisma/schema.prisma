// Prisma schema — single source of truth for the database.
// Change the schema via migrations only (never by hand).
// Multi-tenancy: nearly every table carries a tenantId; queries must be tenant-scoped.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  MANAGER
  AGENT
  READ_ONLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
}

enum OnboardingTaskStatus {
  PENDING
  DONE
  SKIPPED
}

enum CatalogItemType {
  SERVICE
  PRODUCT
  PACKAGE
  ADDON
}

enum PricingUnit {
  FIXED
  MONTHLY
  PER_UNIT
}

enum ClientStatus {
  LEAD
  ACTIVE
  INACTIVE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum ContactStage {
  NEW
  CONTACTED
  INTERESTED
  QUALIFIED
  WON
  LOST
}

enum ContactActivityType {
  CALL
  EMAIL
  WHATSAPP
  SMS
  AD
  MEETING
  NOTE
}

enum ContactActivityOutcome {
  CONNECTED
  NO_ANSWER
  INTERESTED
  NOT_INTERESTED
  FOLLOW_UP
  BOUNCED
  DONE
}

enum QuoteTemplate {
  CLASSIC
  MODERN
  MINIMALIST
  PROFESSIONAL
  BOLD
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  VOID
}

enum PaymentMethod {
  CASH
  BKASH
  NAGAD
  ROCKET
  BANK_TRANSFER
  CHEQUE
  CARD
  OTHER
}

enum InvoiceEventType {
  CREATED
  SENT
  VIEWED
  PAYMENT_RECORDED
  PAID
  VOIDED
}

enum QuoteEventType {
  CREATED
  SENT
  VIEWED
  APPROVED
  REJECTED
  COMMENTED
  CONVERTED
}

/// A workspace = a tenant (a company or agency). The Owner is the subscriber.
model Tenant {
  id                   String    @id @default(cuid())
  name                 String
  slug                 String    @unique
  logoUrl              String?
  timezone             String    @default("Asia/Dhaka")
  currency             String    @default("BDT")
  businessType         String?
  defaultQuoteTemplate QuoteTemplate @default(CLASSIC)
  onboardingCompletedAt DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  users           User[]
  subscription    Subscription?
  onboardingTasks OnboardingTask[]
  catalogItems    CatalogItem[]
  clients         Client[]
  quotes          Quote[]
  contacts        Contact[]
  contactActivities ContactActivity[]
  invoices        Invoice[]
  payments        Payment[]

  @@map("tenants")
}

/// A step in the agency's getting-started checklist (seeded on registration).
model OnboardingTask {
  id          String               @id @default(cuid())
  tenantId    String
  key         String
  title       String
  status      OnboardingTaskStatus @default(PENDING)
  order       Int                  @default(0)
  completedAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("onboarding_tasks")
}

/// Tenant-level subscription. Gates platform access for every user in the tenant.
model Subscription {
  id               String             @id @default(cuid())
  tenantId         String             @unique
  status           SubscriptionStatus @default(TRIALING)
  plan             String             @default("trial")
  maxSubUsers      Int                @default(10)
  currentPeriodEnd DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model User {
  id           String    @id @default(cuid())
  tenantId     String
  email        String    @unique
  name         String
  phone        String?
  passwordHash String
  role         UserRole  @default(AGENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]
  assignedContacts  Contact[]         @relation("ContactAssignee")
  contactActivities ContactActivity[] @relation("ActivityAuthor")
  invoicesCreated   Invoice[]         @relation("InvoiceCreatedBy")
  paymentsRecorded  Payment[]         @relation("PaymentRecordedBy")

  @@index([tenantId])
  @@map("users")
}

/// A saved service / product / package / add-on the agency quotes from.
/// Money is stored as integer minor units (BDT poisha), never floats.
model CatalogItem {
  id          String          @id @default(cuid())
  tenantId    String
  type        CatalogItemType @default(SERVICE)
  name        String
  description String?
  category    String?
  pricingUnit PricingUnit     @default(FIXED)
  priceMinor  Int             @default(0)
  currency    String          @default("BDT")
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quoteLines   QuoteLineItem[]
  invoiceLines InvoiceLineItem[]

  @@index([tenantId])
  @@index([tenantId, type])
  @@map("catalog_items")
}

/// A quotation sent to a client. Totals are computed server-side (never trusted
/// from the client) and stored in integer minor units (BDT poisha).
model Quote {
  id             String      @id @default(cuid())
  tenantId       String
  number         String
  clientId       String?
  // Ad-hoc recipient name when the quote isn't linked to a saved client.
  customerName   String?
  status         QuoteStatus @default(DRAFT)
  // Per-quote template override; null falls back to the tenant's defaultQuoteTemplate.
  template       QuoteTemplate?
  currency       String      @default("BDT")
  issueDate      DateTime    @default(now())
  expiresAt      DateTime?
  note           String?
  terms          String?
  taxRatePercent Int         @default(0)
  discountMinor  Int         @default(0)
  subtotalMinor  Int         @default(0)
  taxMinor       Int         @default(0)
  totalMinor     Int         @default(0)
  createdById    String?
  // Client-facing public link + e-signature approval trail
  publicToken     String?   @unique
  sentAt          DateTime?
  viewedAt        DateTime?
  respondedAt     DateTime?
  signerName      String?
  approvalIp      String?
  rejectionReason String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  lineItems QuoteLineItem[]
  events    QuoteEvent[]
  invoice   Invoice?

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("quotes")
}

/// Timeline of everything that happened to a quote (created, sent, viewed, approved…).
model QuoteEvent {
  id        String         @id @default(cuid())
  quoteId   String
  type      QuoteEventType
  message   String?
  actor     String?
  createdAt DateTime       @default(now())

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_events")
}

model QuoteLineItem {
  id                String  @id @default(cuid())
  quoteId           String
  catalogItemId     String?
  description       String
  unit              String  @default("FIXED")
  quantity          Int     @default(1)
  unitPriceMinor    Int     @default(0)
  lineDiscountMinor Int     @default(0)
  lineTotalMinor    Int     @default(0)
  sortOrder         Int     @default(0)

  quote       Quote        @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@map("quote_line_items")
}

/// A bill sent to a client. Totals mirror the quote (integer minor units). Payments are
/// recorded manually; `amountPaidMinor` is kept in sync and the status derives from it.
model Invoice {
  id              String         @id @default(cuid())
  tenantId        String
  number          String
  clientId        String?
  customerName    String?
  quoteId         String?        @unique
  status          InvoiceStatus  @default(DRAFT)
  currency        String         @default("BDT")
  issueDate       DateTime       @default(now())
  dueDate         DateTime?
  note            String?
  terms           String?
  taxRatePercent  Int            @default(0)
  discountMinor   Int            @default(0)
  subtotalMinor   Int            @default(0)
  taxMinor        Int            @default(0)
  totalMinor      Int            @default(0)
  amountPaidMinor Int            @default(0)
  template        QuoteTemplate?
  publicToken     String?        @unique
  sentAt          DateTime?
  viewedAt        DateTime?
  paidAt          DateTime?
  voidedAt        DateTime?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  quote     Quote?            @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  createdBy User?             @relation("InvoiceCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  lineItems InvoiceLineItem[]
  payments  Payment[]
  events    InvoiceEvent[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("invoices")
}

model InvoiceLineItem {
  id                String  @id @default(cuid())
  invoiceId         String
  catalogItemId     String?
  description       String
  unit              String  @default("FIXED")
  quantity          Int     @default(1)
  unitPriceMinor    Int     @default(0)
  lineDiscountMinor Int     @default(0)
  lineTotalMinor    Int     @default(0)
  sortOrder         Int     @default(0)

  invoice     Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  catalogItem CatalogItem? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@map("invoice_line_items")
}

/// A single manually-recorded payment against an invoice (supports partial payments).
model Payment {
  id           String        @id @default(cuid())
  tenantId     String
  invoiceId    String
  amountMinor  Int
  method       PaymentMethod @default(CASH)
  reference    String?
  paidAt       DateTime      @default(now())
  note         String?
  recordedById String?
  createdAt    DateTime      @default(now())

  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  recordedBy User?   @relation("PaymentRecordedBy", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([invoiceId])
  @@map("payments")
}

/// Timeline of everything that happened to an invoice (created, sent, paid, voided…).
model InvoiceEvent {
  id        String           @id @default(cuid())
  invoiceId String
  type      InvoiceEventType
  message   String?
  actor     String?
  createdAt DateTime         @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_events")
}

/// A client (the agency's customer) that quotations, invoices, and tickets attach to.
model Client {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  notes       String?
  status      ClientStatus @default(ACTIVE)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quotes   Quote[]
  invoices Invoice[]
  // The prospect this client was converted from (Contacts module), if any.
  fromContact Contact? @relation("ClientFromContact")

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("clients")
}

/// A prospect / potential client for outbound sales. Lives in the Contacts (lead) pipeline
/// until it converts into a Client. Outreach touches are tracked in ContactActivity.
model Contact {
  id                String       @id @default(cuid())
  tenantId          String
  name              String
  company           String?
  email             String?
  mobile            String?
  whatsapp          String?
  source            String?
  stage             ContactStage @default(NEW)
  tags              String[]     @default([])
  notes             String?
  assignedToId      String?
  convertedClientId String?      @unique
  lastContactedAt   DateTime?
  nextFollowUpAt    DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignedTo      User?             @relation("ContactAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  convertedClient Client?           @relation("ClientFromContact", fields: [convertedClientId], references: [id], onDelete: SetNull)
  activities      ContactActivity[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, assignedToId])
  @@map("contacts")
}

/// A single outreach touch on a contact (cold call, cold email, WhatsApp, ad, note…).
model ContactActivity {
  id             String                  @id @default(cuid())
  tenantId       String
  contactId      String
  type           ContactActivityType
  outcome        ContactActivityOutcome?
  note           String?
  occurredAt     DateTime                @default(now())
  nextFollowUpAt DateTime?
  createdById    String?
  createdAt      DateTime                @default(now())

  tenant    Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("ActivityAuthor", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([contactId])
  @@map("contact_activities")
}

/// Hashed refresh tokens for rotation + revocation (one row per active session).
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}
