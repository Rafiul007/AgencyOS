{
  "name": "agencyos",
  "version": "0.0.1",
  "private": true,
  "description": "AgencyOS — multi-tenant SaaS for companies and marketing agencies",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "backend:dev": "pnpm --filter @agencyos/backend start:dev",
    "backend:build": "pnpm --filter @agencyos/backend build",
    "frontend:dev": "pnpm --filter @agencyos/frontend dev",
    "frontend:build": "pnpm --filter @agencyos/frontend build",
    "shared:build": "pnpm --filter @agencyos/shared build",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,css}": "prettier --write"
  }
}
